{
  "name": "readdown",
  "version": "0.2.1",
  "description": "HTML to clean Markdown optimized for LLMs. One function: HTML in, token-efficient Markdown out.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "readdown": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format cjs,esm --dts --clean",
    "prepare": "npm run build",
    "test": "node test.js"
  },
  "keywords": [
    "markdown",
    "html-to-markdown",
    "readability",
    "llm",
    "ai",
    "rag",
    "content-extraction",
    "web-scraping",
    "token-efficient",
    "chatgpt",
    "claude",
    "turndown-alternative"
  ],
  "author": "zcag",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zcag/readdown"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/zcag"
  },
  "dependencies": {
    "linkedom": "^0.18.12"
  },
  "devDependencies": {
    "@mozilla/readability": "^0.6.0",
    "@types/node": "^25.4.0",
    "@vercel/ncc": "^0.38.4",
    "defuddle": "^0.12.0",
    "tsup": "^8.0.0",
    "turndown": "^7.2.2",
    "typescript": "^5.4.0"
  }
}
